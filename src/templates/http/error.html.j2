<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 3.2 Final//EN">
<html>
<head>
<title>{{ status_code }} {{ status_text }}</title>
<style>
body {
  font-family: {{ theme.font }};
  margin: 40px;
  line-height: 1.6;
  background: {{ theme.bg }};
  color: {{ theme.fg }};
  {% if theme.font_size %}font-size: {{ theme.font_size }};{% endif %}
}
h1 { margin-bottom: 20px; color: {{ theme.error }}; }
.error-box {
  max-width: 600px;
  padding: 30px;
  border-radius: 8px;
  background: {{ theme.th_bg }};
  border: 1px solid {{ theme.border }};
}
address {
  font-style: normal;
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid {{ theme.border }};
  font-size: 0.9em;
  color: {{ theme.muted }};
}
</style>
{% if custom_css %}<style>{{ custom_css }}</style>{% endif %}
</head>
<body>
<div class="error-box">
<h1>{{ status_code }} {{ status_text }}</h1>
<p>{{ message }}</p>
<hr>
<address>{{ server_name }}</address>
</div>
</body>
</html>
